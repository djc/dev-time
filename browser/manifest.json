{
  "manifest_version": 2,
  "name": "Dev Time",
  "version": "0.1.0",
  "description": "Tracks time spent on URLs locally and syncs to a remote server hourly.",
  "permissions": ["tabs", "storage", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  }
}
